# ===================================
# Database
# ===================================

# PostgreSQL (本番環境)
DATABASE_URL="postgresql://username:password@localhost:5432/chatapp?schema=public"

# SQLite (ローカル開発)
# DATABASE_URL="file:./dev.db"

# ===================================
# NextAuth.js
# ===================================

# ランダムなシークレットキー (openssl rand -base64 32 で生成)
NEXTAUTH_SECRET="your-secret-key-here-change-this-in-production"

# アプリケーションURL
NEXTAUTH_URL="http://localhost:3000"

# ===================================
# OAuth Providers
# ===================================

# Google OAuth
# https://console.cloud.google.com/
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth
# https://github.com/settings/developers
GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"

# ===================================
# Public Environment Variables
# ===================================

# アプリケーションURL (クライアント側)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===================================
# File Upload (オプション)
# ===================================

# Cloudinary
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"

# Vercel Blob
# BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"

# AWS S3
# AWS_REGION="ap-northeast-1"
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_S3_BUCKET="your-bucket-name"

# ===================================
# WebSocket / Realtime (オプション)
# ===================================

# Pusher
# PUSHER_APP_ID="your-app-id"
# PUSHER_KEY="your-key"
# PUSHER_SECRET="your-secret"
# PUSHER_CLUSTER="ap1"
# NEXT_PUBLIC_PUSHER_KEY="your-key"
# NEXT_PUBLIC_PUSHER_CLUSTER="ap1"

# Ably
# ABLY_API_KEY="your-ably-api-key"
# NEXT_PUBLIC_ABLY_KEY="your-public-key"

# ===================================
# Email (オプション)
# ===================================

# SendGrid
# SENDGRID_API_KEY="your-sendgrid-api-key"
# EMAIL_FROM="noreply@yourdomain.com"

# Resend
# RESEND_API_KEY="your-resend-api-key"

# ===================================
# Monitoring & Analytics (オプション)
# ===================================

# Sentry
# SENTRY_DSN="your-sentry-dsn"
# NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"

# Vercel Analytics
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID="your-analytics-id"

# ===================================
# Development (開発環境のみ)
# ===================================

# ログレベル
# LOG_LEVEL="debug"

# Prisma Studio ポート
# PRISMA_STUDIO_PORT="5555"
