# =============================================================================
# next-app-chat 環境変数テンプレート
#
# 使い方:
#   1. このファイルを `.env` にコピー: `cp .env.example .env`
#   2. 必須項目 (# Required と書かれた行) を埋める
#   3. 機能を有効化する任意項目があればまとめてセットする (片欠け禁止)
#
# Source of Truth:
#   - 検証スキーマ: `src/lib/config/env.ts` (Zod)
#   - ローカル手順: `docs/usages/local-setup.md`
#
# Note:
#   - .env はリポジトリにコミットしない (`.gitignore` で除外済)
#   - secret 系は本番で必ず再生成する
# =============================================================================

# -----------------------------------------------------------------------------
# Node.js 環境
# -----------------------------------------------------------------------------
NODE_ENV="development"

# -----------------------------------------------------------------------------
# ログレベル (Optional)
# -----------------------------------------------------------------------------
# Optional — サーバーログの詳細度。開発時は "debug" 推奨。
# 値: fatal | error | warn | info | debug | trace
LOG_LEVEL="info"

# -----------------------------------------------------------------------------
# Database (Prisma)
# -----------------------------------------------------------------------------
# Required
# PostgreSQL 接続文字列。`docker compose up -d` でローカル DB を起動してから設定する。
# 形式: postgresql://user:password@host:port/dbname?schema=public
DATABASE_URL=postgresql://app:app@localhost:54324/app?schema=public

# -----------------------------------------------------------------------------
# NextAuth.js 認証
# -----------------------------------------------------------------------------
# Required
# セッション暗号化キー。32 文字以上必須。
# 生成: openssl rand -base64 48
NEXTAUTH_SECRET=""
# Required
# アプリの公開 URL (開発: http://localhost:3000)
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Google OAuth (Optional)
# GOOGLE_CLIENT_ID と GOOGLE_CLIENT_SECRET は両方セットするか、両方未設定にすること。
# 片方だけ設定すると起動時に "Google OAuth keys must be all-set or all-unset" で失敗する。
# 取得: https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# GitHub OAuth (Optional) — Auth.js v5 命名
# GITHUB_ID と GITHUB_SECRET は両方セットするか、両方未設定にすること。
# 片方だけ設定すると起動時に "GitHub OAuth keys must be all-set or all-unset" で失敗する。
# 取得: https://github.com/settings/developers
# -----------------------------------------------------------------------------
GITHUB_ID=""
GITHUB_SECRET=""

# -----------------------------------------------------------------------------
# SMTP メール送信 (Optional)
# SMTP_HOST / SMTP_USER / SMTP_PASSWORD は 3 つすべてセットするか、すべて未設定にすること。
# Gmail: smtp.gmail.com (ポート 587) / Outlook: smtp-mail.outlook.com (ポート 587)
# -----------------------------------------------------------------------------
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
# Optional — 送信元メールアドレス (例: noreply@example.com)
SMTP_FROM_EMAIL=""
# Optional — 送信元表示名 (例: Chat)
SMTP_FROM_NAME=""

# -----------------------------------------------------------------------------
# 暗号化キー (Optional)
# -----------------------------------------------------------------------------
# Optional — AES-256 暗号化キー。メッセージの暗号化に使用。
# 形式: 64 文字の hex 文字列 (32 バイト = AES-256)
# 生成: openssl rand -hex 32
ENCRYPTION_KEY=""

# -----------------------------------------------------------------------------
# Upstash Redis — レート制限 (Optional)
# UPSTASH_REDIS_REST_URL と UPSTASH_REDIS_REST_TOKEN は両方セットするか、両方未設定にすること。
# 取得: https://upstash.com/ でコンソール作成後、Redis データベースのページから取得
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# -----------------------------------------------------------------------------
# Pusher — リアルタイム通信 (Optional)
# Pusher (server) の 4 キーはすべてセットするか、すべて未設定にすること。
# Pusher (public) の 2 キーも同様。
# 取得: https://pusher.com/
# -----------------------------------------------------------------------------
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""

# -----------------------------------------------------------------------------
# Cron ジョブ認証
# -----------------------------------------------------------------------------
# Optional (本番では Required) — Cron API エンドポイントの認証シークレット。32 文字以上。
# 生成: openssl rand -base64 48
CRON_SECRET=""

# -----------------------------------------------------------------------------
# Cloudflare R2 / MinIO — 画像ストレージ (Optional)
# R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY / R2_BUCKET_NAME / R2_ENDPOINT は
# 4 つすべてセットするか、すべて未設定にすること (片欠け禁止)。
# R2_PUBLIC_URL はオプション: カスタムドメインや CDN URL がある場合に設定する。
#
# 本番 (Cloudflare R2):
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""
# R2_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
# R2_PUBLIC_URL=""
#
# ローカル (MinIO — docker compose up -d で起動):
R2_ACCESS_KEY_ID="minioadmin"
R2_SECRET_ACCESS_KEY="minioadmin"
R2_BUCKET_NAME="chat-app"
R2_ENDPOINT="http://localhost:9000"
R2_PUBLIC_URL="http://localhost:9000/chat-app"

# -----------------------------------------------------------------------------
# Stripe — サブスクリプション決済 (Optional)
# STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET / STRIPE_BASIC_PRICE_ID / STRIPE_PREMIUM_PRICE_ID は
# すべてセットするか、すべて未設定にすること。
# 取得: https://dashboard.stripe.com/apikeys (Secret key)
#       https://dashboard.stripe.com/webhooks (Webhook signing secret)
#       https://dashboard.stripe.com/products (Price ID)
# ローカルWebhookテスト: stripe listen --forward-to localhost:3000/api/billing/webhook
# -----------------------------------------------------------------------------
# ローカル (stripe-mock — docker compose で自動起動)
STRIPE_SECRET_KEY="sk_test_123"
STRIPE_WEBHOOK_SECRET="whsec_test_localmocksecret1234567890ab"
STRIPE_BASIC_PRICE_ID="price_mock_basic_monthly"
STRIPE_PREMIUM_PRICE_ID="price_mock_premium_monthly"
STRIPE_API_BASE_URL="http://localhost:12111"
# 本番に切り替える際は STRIPE_SECRET_KEY を実際の値に、STRIPE_API_BASE_URL を削除する

# Webhook のローカルテスト (stripe-mock 自体は Webhook 送信を行わない):
#   1. stripe CLI をインストール: https://stripe.com/docs/stripe-cli
#   2. stripe listen --forward-to http://localhost:3000/api/billing/webhook
#   3. 表示された whsec_... を STRIPE_WEBHOOK_SECRET に設定してサーバーを再起動

# -----------------------------------------------------------------------------
# Public 環境変数 (クライアントバンドルに埋め込まれる)
# NEXT_PUBLIC_ プレフィックス付きの値は そのままブラウザに送信される。
# 秘密情報 (API key の write 権限、DB 接続文字列、署名鍵) を絶対に入れないこと。
# -----------------------------------------------------------------------------
# Optional — アプリの公開 URL (OG 画像・sitemap の絶対 URL に使用)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional — Pusher 公開キー (Pusher (server) と同時にセットすること)
NEXT_PUBLIC_PUSHER_KEY=""
# Optional — Pusher クラスター (Pusher (server) と同時にセットすること)
NEXT_PUBLIC_PUSHER_CLUSTER=""
