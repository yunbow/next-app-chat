    "@tanstack/react-query": "^5.28.0",
    "@uiw/react-markdown-preview": "^5.1.3",
    "@upstash/redis": "^1.37.0",
    "bcrypt": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "geist": "^1.7.0",
    "lucide-react": "^0.577.0",
    "next": "^14.2.0",
    "next-auth": "^4.24.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "pusher": "^5.2.0",
    "pusher-js": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
